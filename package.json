{
  "name": "reflex-coffee",
  "version": "0.1.0",
  "description": "Interactive TUI demo of @corpus-relica/reflex — a coffee shop order workflow",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=production tsx src/main.tsx",
    "dev:web": "vite --config web/vite.config.ts",
    "build": "tsc",
    "build:web": "vite build --config web/vite.config.ts",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@corpus-relica/reflex": "file:../reflex/typescript",
    "ink": "^6.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
